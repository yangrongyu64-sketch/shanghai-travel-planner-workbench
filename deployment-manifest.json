{
  "app_name": "上海攻略生成工作台",
  "package_type": "static_site",
  "default_entry": "index.html",
  "entries": {
    "demo": "index.html",
    "workbench": "workbench.html"
  },
  "download_files": [
    "workbench-demo.zip",
    "miniprogram-handoff.zip",
    "maintenance-report.zip"
  ],
  "pwa": {
    "manifest": "manifest.webmanifest",
    "service_worker": "service-worker.js",
    "icon": "app-icon.svg",
    "installable_entry": "index.html"
  },
  "miniprogram_handoff": {
    "directory": "miniprogram-handoff",
    "archive": "miniprogram-handoff.zip",
    "target": "微信小程序 / 移动端壳"
  },
  "maintenance": {
    "directory": "maintenance",
    "archive": "maintenance-report.zip",
    "health_report": "maintenance/health-report.json"
  },
  "deploy_scripts": {
    "github_pages": "deploy-github-pages.sh"
  },
  "deployment_targets": [
    "GitHub Pages",
    "Vercel",
    "Netlify",
    "静态文件服务器"
  ],
  "smoke_checks": [
    "根路径打开后显示上海攻略生成工作台",
    "演示版自动填充发布工作台",
    "普通工作台入口 workbench.html 可访问",
    "离线演示包 workbench-demo.zip 可下载",
    "维护健康包 maintenance-report.zip 可下载",
    "PWA manifest 可访问且 service worker 可注册"
  ],
  "live_deployment": {
    "status": "published",
    "published_url": "https://yangrongyu64-sketch.github.io/shanghai-travel-planner-workbench/",
    "workbench_url": "https://yangrongyu64-sketch.github.io/shanghai-travel-planner-workbench/workbench.html",
    "download_url": "https://yangrongyu64-sketch.github.io/shanghai-travel-planner-workbench/workbench-demo.zip",
    "repository_url": "https://github.com/yangrongyu64-sketch/shanghai-travel-planner-workbench",
    "published_at": "2026-07-11"
  }
}
